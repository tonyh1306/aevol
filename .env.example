# PostgreSQL
POSTGRES_DB=evaldb
POSTGRES_USER=eval
POSTGRES_PASSWORD=changeme_in_production

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=changeme_in_production
LOG_LEVEL=INFO
WORKER_DEAD_THRESHOLD=30
TASK_LOCK_TTL=60
MAX_UPLOAD_SIZE_MB=100

# LLM providers (workers use these)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Frontend
# Empty = same-origin via nginx. Set to http://localhost:8000 for dev without nginx.
NEXT_PUBLIC_API_URL=
