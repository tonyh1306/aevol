# PostgreSQL
POSTGRES_DB=agentjudge
POSTGRES_USER=agentjudge
POSTGRES_PASSWORD=changeme_in_production

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
LOG_LEVEL=INFO

# LLM providers — at least one required for evaluation
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Frontend
# Empty = same-origin via nginx. Set to http://localhost:8000 for dev without nginx.
NEXT_PUBLIC_API_URL=
